DEPCOVER_USE_FAKES=false

# Butterbase
DEPCOVER_BUTTERBASE_BASE_URL=https://YOUR-BUTTERBASE-PROJECT.example
DEPCOVER_BUTTERBASE_KEY_ENV=BUTTERBASE_SERVICE_KEY
BUTTERBASE_SERVICE_KEY=replace-me

# Neo4j Aura or self-hosted Neo4j
DEPCOVER_NEO4J_URI=neo4j+s://YOUR-INSTANCE.databases.neo4j.io
DEPCOVER_NEO4J_USER=neo4j
DEPCOVER_NEO4J_PASSWORD_ENV=NEO4J_PASSWORD
NEO4J_PASSWORD=replace-me

# Daytona / pipeline runtime
DEPCOVER_DAYTONA_SNAPSHOT_ID=replace-me
DEPCOVER_SANDBOX_EXEC_TIMEOUT_S=300
DEPCOVER_SANDBOX_ACQUIRE_TIMEOUT_S=30

# Optional GitHub polling / PR automation
DEPCOVER_GITHUB_TOKEN_ENV=GITHUB_TOKEN
GITHUB_TOKEN=replace-me
DEPCOVER_GITHUB_POLL_INTERVAL_S=10

# OpenAI-compatible LLM roles. Each API_KEY_ENV points at the env var
# containing that role's secret, so Settings never stores raw secrets.
DEPCOVER_LLM_TRANSPLANT_BASE_URL=https://api.openai.com/v1
DEPCOVER_LLM_TRANSPLANT_MODEL=gpt-4.1
DEPCOVER_LLM_TRANSPLANT_API_KEY_ENV=OPENAI_API_KEY

DEPCOVER_LLM_JUDGE_CORRECTNESS_BASE_URL=https://api.openai.com/v1
DEPCOVER_LLM_JUDGE_CORRECTNESS_MODEL=gpt-4.1
DEPCOVER_LLM_JUDGE_CORRECTNESS_API_KEY_ENV=OPENAI_API_KEY

DEPCOVER_LLM_JUDGE_SECURITY_BASE_URL=https://api.openai.com/v1
DEPCOVER_LLM_JUDGE_SECURITY_MODEL=gpt-4.1
DEPCOVER_LLM_JUDGE_SECURITY_API_KEY_ENV=OPENAI_API_KEY

DEPCOVER_LLM_JUDGE_MINIMALITY_BASE_URL=https://api.openai.com/v1
DEPCOVER_LLM_JUDGE_MINIMALITY_MODEL=gpt-4.1
DEPCOVER_LLM_JUDGE_MINIMALITY_API_KEY_ENV=OPENAI_API_KEY

DEPCOVER_LLM_JUDGE_RECIPE_BASE_URL=https://api.openai.com/v1
DEPCOVER_LLM_JUDGE_RECIPE_MODEL=gpt-4.1
DEPCOVER_LLM_JUDGE_RECIPE_API_KEY_ENV=OPENAI_API_KEY

DEPCOVER_LLM_MITIGATION_BASE_URL=https://api.openai.com/v1
DEPCOVER_LLM_MITIGATION_MODEL=gpt-4.1
DEPCOVER_LLM_MITIGATION_API_KEY_ENV=OPENAI_API_KEY

DEPCOVER_LLM_PR_SCREEN_BASE_URL=https://api.openai.com/v1
DEPCOVER_LLM_PR_SCREEN_MODEL=gpt-4.1
DEPCOVER_LLM_PR_SCREEN_API_KEY_ENV=OPENAI_API_KEY

OPENAI_API_KEY=replace-me
